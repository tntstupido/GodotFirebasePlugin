[config]
name="FirebasePlugin"
binary="FirebasePlugin.xcframework"
initialization="init_firebase_plugin"
deinitialization="deinit_firebase_plugin"
use_swift_runtime=true

[dependencies]
linked=[]
embedded=[
	"FirebaseAnalytics.xcframework",
	"FirebaseCrashlytics.xcframework",
	"FirebaseRemoteConfig.xcframework"
]
system=[
	"Foundation.framework",
	"JavaScriptCore.framework",
	"UIKit.framework"
]
files=[]
linker_flags=[
	"-ObjC"
]
